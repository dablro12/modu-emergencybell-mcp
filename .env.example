# Kakao Developers → 앱 → REST API 키 (Local API)
# https://developers.kakao.com/docs/ko/local/dev-guide
KAKAO_REST_API_KEY=

# 공공데이터포털 일반 인증키 (Decoding 권장)
# https://www.data.go.kr/
DATA_GO_KR_SERVICE_KEY=

# 동일 키 Encoding 버전 (일부 API 403 시 fallback)
DATA_GO_KR_SERVICE_KEY_ENCODED=

# GitHub push (로컬 전용, 커밋하지 않음)
GITHUB_TOKEN=

MCP_HOST=0.0.0.0
MCP_PORT=8000
