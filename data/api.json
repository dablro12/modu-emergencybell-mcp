      "implementation": {
        "tool": "get_emergency_hotlines",
        "purpose_ko": "「이 상황에서 어디에 전화해야 해?」에 답함 — 핫라인 목록이 아닌 상황별 전화 안내",
        "params": {
          "situation_description": {
            "type": "string",
            "required": true,
            "description_ko": "사용자가 말한 상황 그대로. 예: '화장실에서 넘어졌어', '119랑 1339 차이', '외국인인데 병원'"
          },
          "situation": {
            "type": "string",
            "required": false,
            "enum": [
              "life_threatening",
              "medical_urgent",
              "restroom_help",
              "foreign_visitor",
              "poison",
              "police",
              "mental_crisis",
              "school_violence",
              "utility_electric",
              "utility_gas",
              "safety_hazard",
              "unsure"
            ],
            "description_ko": "호스트 AI가 이미 분류한 경우. 없으면 keywords_ko로 자동 매칭"
          },
          "language": {
            "type": "string",
            "enum": ["ko", "en"],
            "default": "ko"
          }
        },
        "response": "markdown — headline「이 상황에서는 → ○○」+ 번호 상세 + restroom_bell + disclaimer + next_tool",
        "matching": "keywords_ko in situation_routing; fallback unsure; explicit situation param wins",
        "latency_target_ms": 100
